<div class="container mt-4">
	<div class="row">
		<div class="col-md-8">
			<h1 class="mb-3"><%= @product.name %></h1>
			<p class="lead"><%= @product.description %></p>
			<p><strong>Price:</strong> $<%= @product.price %></p>
			<p><strong>Stock:</strong> <%= @product.stock_quantity %></p>
			<%= button_to 'Add to Cart', add_cart_path(product_id: @product.id, quantity: 1), method: :post, class: 'btn btn-success' %>
		</div>
	</div>
	<div class="row mt-5">
		<div class="col-md-8">
			<h4>Reviews</h4>
			<% if @reviews.any? %>
				<% @reviews.each do |review| %>
					<div class="card mb-2">
						<div class="card-body">
							<strong>Rating:</strong> <%= review.rating %> / 5<br>
							<%= review.comment %>
							<div class="text-muted small">by User <%= review.user_id %> at <%= review.created_at.strftime('%Y-%m-%d') %></div>
						</div>
					</div>
				<% end %>
			<% else %>
				<p class="text-muted">No reviews yet.</p>
			<% end %>
		</div>
	</div>
</div>
