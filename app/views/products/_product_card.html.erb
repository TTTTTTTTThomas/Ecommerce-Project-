<div class="card h-100 shadow-sm">
  <div class="card-body d-flex flex-column">
    <h5 class="card-title"><%= link_to product.name, product_path(product), class: "text-decoration-none" %></h5>
    <p class="card-text"><%= truncate(product.description, length: 80) %></p>
    <p class="card-text fw-bold">$<%= product.price %></p>
    <p class="card-text text-muted">Stock: <%= product.stock_quantity %></p>
    <%= button_to 'Add to Cart', add_cart_path(product_id: product.id, quantity: 1), method: :post, class: "btn btn-success mt-auto" %>
  </div>
</div>
