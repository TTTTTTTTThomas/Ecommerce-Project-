<div class="container mt-4">
	<h1 class="mb-4">All Orders</h1>
	<table class="table table-bordered align-middle">
		<thead class="table-light">
			<tr>
				<th>ID</th>
				<th>User</th>
				<th>Status</th>
				<th>Total Price</th>
				<th>Created At</th>
				<th></th>
			</tr>
		</thead>
		<tbody>
			<% @orders.each do |order| %>
				<tr>
					<td><%= order.id %></td>
					<td><%= order.user_id %></td>
					<td><%= order.status %></td>
					<td>$<%= order.total_price %></td>
					<td><%= order.created_at.strftime('%Y-%m-%d %H:%M') %></td>
					<td><%= link_to 'View', order_path(order), class: 'btn btn-sm btn-info' %></td>
				</tr>
			<% end %>
		</tbody>
	</table>
	<%= link_to 'Back to Products', root_path, class: 'btn btn-primary' %>
</div>
