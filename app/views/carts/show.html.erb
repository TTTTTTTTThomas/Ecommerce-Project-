<div class="container mt-4">
  <h1 class="mb-4">Your Shopping Cart</h1>
  <% if @cart_items.present? %>
    <table class="table table-bordered align-middle">
      <thead class="table-light">
        <tr>
          <th>Product</th>
          <th>Quantity</th>
          <th>Price</th>
          <th>Subtotal</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% total = 0 %>
        <% @cart_items.each do |item| %>
          <% subtotal = item[:product].price * item[:quantity] %>
          <% total += subtotal %>
          <tr>
            <td><%= link_to item[:product].name, product_path(item[:product]) %></td>
            <td><%= item[:quantity] %></td>
            <td>$<%= item[:product].price %></td>
            <td>$<%= subtotal %></td>
            <td>
              <%= button_to 'Remove', remove_cart_path(product_id: item[:product].id), method: :post, class: 'btn btn-danger btn-sm' %>
            </td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
        <tr>
          <th colspan="3" class="text-end">Total:</th>
          <th colspan="2">$<%= total %></th>
        </tr>
      </tfoot>
    </table>
    <%= link_to 'Checkout', new_order_path, class: 'btn btn-success' %>
  <% else %>
    <p class="text-muted">Your cart is empty.</p>
  <% end %>
</div>
